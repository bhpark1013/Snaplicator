# Snaplicator environment configuration.
# Copy this file to configs/.env and fill in real values:
#   cp configs/.env.example configs/.env

# ─── Replica container ────────────────────────────────────────────
CONTAINER_NAME=snaplicator_replica
NETWORK_NAME=pg_replication_network
HOST_PORT=5432

POSTGRES_USER=replica_user
POSTGRES_PASSWORD=change-me-replica-password
POSTGRES_DB=mydb

# Stock image. Use a custom image if you need extra extensions (HLL, vector, etc.):
POSTGRES_IMAGE=postgres:15-alpine
# POSTGRES_IMAGE=yourorg/postgres-custom:15-alpine

# ─── btrfs storage ────────────────────────────────────────────────
ROOT_DATA_DIR=/data/snaplicator
MAIN_DATA_DIR=replica

# ─── Primary (publisher) connection ───────────────────────────────
PRIMARY_HOST=primary.example.com
PRIMARY_PORT=5432
PRIMARY_DB=mydb
PRIMARY_USER=replication_user
PRIMARY_PASSWORD=change-me-primary-password
# PGSSLMODE=require

# Logical replication
PUBLICATION_NAME=snaplicator_publication
SUBSCRIPTION_NAME=snaplicator_subscription

# Schemas to schema-clone (DDL) from primary. Row data is filled either by
# logical replication (tables in PUBLICATION) or by postgres_fdw (tables in
# configs/fdw.yaml). Comma-separated.
DUMP_SCHEMAS=public


# ─── FDW (postgres_fdw) ───────────────────────────────────────────
# Live read-only access to primary via a dedicated role, managed via the
# Replication UI (configs/fdw.yaml is the source of truth).
#
# Host/port/db may differ from PRIMARY_* (e.g. routed through a bastion or
# pgbouncer). If FDW_HOST/PORT/DB are blank, they fall back to PRIMARY_*.
# Leave FDW_USER/FDW_PASSWORD blank to disable FDW setup entirely.
FDW_USER=
FDW_PASSWORD=
FDW_HOST=
FDW_PORT=
FDW_DB=

# Optional: reuse a manually pre-created replication slot instead of letting
# CREATE SUBSCRIPTION provision one.
# PRECREATED_SLOT_NAME=my_pre_created_slot
