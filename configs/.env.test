# Snaplicator Test Environment
CONTAINER_NAME=snaplicator_test_sub
POSTGRES_USER=testuser
POSTGRES_PASSWORD=testpass
POSTGRES_DB=testdb
HOST_PORT=5556

PRIMARY_HOST=localhost
PRIMARY_PORT=5555
PRIMARY_DB=testdb
PRIMARY_USER=testuser
PRIMARY_PASSWORD=testpass
PUBLICATION_NAME=test_pub
SUBSCRIPTION_NAME=test_sub

NETWORK_NAME=snaplicator-net
ROOT_DATA_DIR=/data/snaplicator
MAIN_DATA_DIR=test-main

POSTGRES_IMAGE=postgres:15-alpine
DUMP_SCHEMAS=public

# FDW (postgres_fdw) credentials, used by the replica to read primary data live
# via foreign tables managed in configs/fdw.yaml. Typically a readonly role on
# the primary. host/port/db are reused from PRIMARY_* above.
# Leave empty to disable FDW setup.
# FDW connection target (optional — if unset, falls back to PRIMARY_HOST/PORT/DB).
# Use a separate bastion or pgbouncer here if you want FDW traffic to bypass
# the same path as logical replication.
FDW_HOST=
FDW_PORT=
FDW_DB=

FDW_USER=
FDW_PASSWORD=
